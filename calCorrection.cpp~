#include "calCorrection.h"

double calCorrection::deltaE_alpha(double E)
{
  const double c1 = 250;
  const double c2 = .00893;
  const double c3 = -5.0645;
  const double c4 = 0.0001;

double deltaE = (E-c1)*c2 + c3 + c4*pow(E-c1,2);
return deltaE;
}

